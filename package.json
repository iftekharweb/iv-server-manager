{
  "name": "iv-server-manager",
  "productName": "IV Server Manager",
  "version": "1.9.2",
  "description": "Desktop app to run, restart, and view logs for any dev server.",
  "main": "src/main/index.js",
  "author": "ImpleVista",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "node scripts/dev.js",
    "build:renderer": "vite build",
    "dist": "vite build && electron-builder --win",
    "dist:publish": "vite build && electron-builder --win --publish always",
    "dist:portable": "vite build && electron-builder --win portable",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:linux": "vite build && electron-builder --linux"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "@lydell/node-pty": "1.2.0-beta.12",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.8.9"
  },
  "build": {
    "appId": "com.implevista.ivservermanager",
    "productName": "IV Server Manager",
    "electronLanguages": [
      "en-US"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "iftekharweb",
        "repo": "iv-server-manager",
        "releaseType": "release"
      }
    ],
    "files": [
      "src/**/*",
      "build/renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/@lydell/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "portable": {
      "artifactName": "IV-Server-Manager-Portable.exe"
    }
  }
}
